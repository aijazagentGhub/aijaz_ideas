<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Daily Points</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 p-4 md:p-10">
    <div class="max-w-4xl mx-auto bg-white shadow-lg rounded-xl p-6">
        <div class="flex justify-between items-center mb-6 border-b pb-4">
            <h1 class="text-2xl font-bold text-gray-800">Daily Points Tracker</h1>
            <button onclick="addRow()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">+ Add Row</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50">
                        <th class="p-3 border-b font-semibold text-gray-600">Point / Description</th>
                        <th class="p-3 border-b font-semibold text-gray-600">Date</th>
                        <th class="p-3 border-b font-semibold text-gray-600">Status</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    </tbody>
            </table>
        </div>
    </div>

    <script>
        // Use existing data or create 5 blank rows for the first time
        let points = JSON.parse(localStorage.getItem('myDailyData'));
        
        if (!points || points.length === 0) {
            points = Array(5).fill().map(() => ({
                text: '',
                date: new Date().toISOString().split('T')[0],
                status: 'Pending'
            }));
        }

        function save() {
            localStorage.setItem('myDailyData', JSON.stringify(points));
        }

        function render() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            points.forEach((item, i) => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50";
                tr.innerHTML = `
                    <td class="p-3 border-b">
                        <input type="text" value="${item.text}" oninput="update(${i}, 'text', this.value)" 
                               placeholder="Type point here..." class="w-full bg-transparent outline-none border-b border-transparent focus:border-blue-400">
                    </td>
                    <td class="p-3 border-b">
                        <input type="date" value="${item.date}" onchange="update(${i}, 'date', this.value)" class="bg-transparent outline-none">
                    </td>
                    <td class="p-3 border-b">
                        <select onchange="update(${i}, 'status', this.value)" class="bg-transparent font-medium outline-none">
                            <option ${item.status === 'Pending' ? 'selected' : ''}>Pending</option>
                            <option ${item.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                            <option ${item.status === 'Done' ? 'selected' : ''}>Done</option>
                        </select>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function update(index, key, value) {
            points[index][key] = value;
            save();
        }

        function addRow() {
            points.push({ text: '', date: new Date().toISOString().split('T')[0], status: 'Pending' });
            save();
            render();
        }

        render();
    </script>
</body>
</html>
